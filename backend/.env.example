# Example environment variables for OrbitX backend
# Copy to .env and fill with real values before starting the server

# Secret key for JWT and security
SECRET_KEY=change_this_to_a_secure_random_value

# SQLAlchemy/Databases
# Example for local Postgres: postgresql+psycopg2://user:password@localhost:5432/orbitx
DATABASE_URL=sqlite:///./dev.db

# N2YO API key (sign up at https://www.n2yo.com/)
N2YO_API_KEY=YOUR_N2YO_API_KEY_HERE

# Optional: Override API prefix
#API_V1_STR=/api/v1
