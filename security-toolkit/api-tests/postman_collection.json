{
  "info": {
    "name": "OrbitX Security API Tests",
    "description": "Verification tests covering authentication, route authorization gates, and satellite telemetry resources.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "User Authenticated Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Login Successful - Token issued\", function () {",
              "    pm.response.to.have.status(200);",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property(\"access_token\");",
              "    pm.environment.set(\"bearer_token\", jsonData.access_token);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{test_user}}\",\n  \"password\": \"{{test_password}}\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/auth/login",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "login"
          ]
        }
      }
    },
    {
      "name": "Access Protected User Profile",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Profile loads successfully\", function () {",
              "    pm.response.to.have.status(200);",
              "    pm.expect(pm.response.json()).to.have.property(\"email\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{bearer_token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/v1/auth/me",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "me"
          ]
        }
      }
    },
    {
      "name": "Access Protected Notes List",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Notes array returns correctly\", function () {",
              "    pm.response.to.have.status(200);",
              "    pm.expect(pm.response.json()).to.be.an(\"array\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "auth": {
          "type": "bearer",
          "bearer": [
            {
              "key": "token",
              "value": "{{bearer_token}}",
              "type": "string"
            }
          ]
        },
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/v1/notes",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "notes"
          ]
        }
      }
    },
    {
      "name": "List Active Satellites",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Satellites collection resolved\", function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/api/v1/tracking/satellites?limit=5",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "tracking",
            "satellites"
          ],
          "query": [
            {
              "key": "limit",
              "value": "5"
            }
          ]
        }
      }
    }
  ]
}
