# OrbitX Testing Environment Variables Template
# Copy to testing.env for local custom testing setups

# Backend Environment
SECRET_KEY=orbitx_jwt_secret_key_for_testing_only_12345
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
PROJECT_NAME="OrbitX Satellite Tracking API (Test)"

# Database Configuration (PostgreSQL Test Instance)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=orbitx_test_db
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/orbitx_test_db

# Frontend / Web E2E (Playwright)
PLAYWRIGHT_TEST_BASE_URL=http://localhost:19006
START_DEV_SERVER=false

# Mobile E2E (Appium / WebdriverIO)
APPIUM_HOST=127.0.0.1
APPIUM_PORT=4723
MOBILE_PLATFORM=android
ANDROID_DEVICE_NAME=Android Emulator
ANDROID_APP_PATH=./mobile/build/OrbitX.apk
IOS_DEVICE_NAME=iPhone 15
IOS_APP_PATH=./mobile/build/OrbitX.app

# Performance Testing (k6)
K6_TARGET_URL=http://127.0.0.1:8000
K6_PROFILE=smoke
